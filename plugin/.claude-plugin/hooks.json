{
  "description": "agentmemory hooks for Claude Code",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_INJECT_CONTEXT=true AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/session-start.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/prompt-submit.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_INJECT_CONTEXT=true AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/pre-tool-use.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-use.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-failure.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.mjs",
            "timeout": 8
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/subagent-start.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/subagent-stop.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/notification.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/task-completed.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/stop.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENTMEMORY_URL=http://127.0.0.1:3111 node ${CLAUDE_PLUGIN_ROOT}/scripts/session-end.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
